# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
APP_URL=https://bowwowsdogspa.com
APP_DEBUG=false

# -----------------------------------------------------------------------------
# Database (GoDaddy shared hosting)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_NAME=bowwowsdogspa
DB_USER=dogspa_admin
DB_PASS=change-me
DB_TEST_NAME=bowwowsdogspa_test

# Only set this to true if you intentionally want backend/tests/run.php to
# back up the configured DB, reuse it for tests, then restore it afterward.
BOWWOW_TEST_REUSE_CONFIGURED_DB=false

# -----------------------------------------------------------------------------
# Browser smoke testing (optional)
# -----------------------------------------------------------------------------
E2E_ADMIN_EMAIL=e2e-admin@bowwow.local
E2E_ADMIN_USERNAME=e2e-admin
E2E_ADMIN_PASSWORD=BowWowE2E123!
# Leave blank to use "today + 14 days" when seeding deterministic booking slots.
E2E_BOOKING_DATE=

# -----------------------------------------------------------------------------
# SendGrid Email
# -----------------------------------------------------------------------------
SENDGRID_ENABLED=true
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@bowwowsdogspa.com
SENDGRID_FROM_NAME="Bow Wow's Dog Spa"
SENDGRID_STAFF_NOTIFICATIONS=bowwowsdogspa@gmail.com
SENDGRID_SEND_CUSTOMER_RECEIPTS=true
SENDGRID_SEND_CUSTOMER_CONFIRMATIONS=true

# -----------------------------------------------------------------------------
# Sessions (admin auth cookies)
# -----------------------------------------------------------------------------
SESSION_NAME=bowwow_admin
SESSION_LIFETIME=14400
SESSION_SECURE=false
SESSION_SAMESITE=Lax

# -----------------------------------------------------------------------------
# Media & Upload Processing
# -----------------------------------------------------------------------------
UPLOAD_DIR=backend/uploads
IMAGE_UPLOAD_MAX_BYTES=8388608
IMAGE_JPEG_QUALITY=88
IMAGE_WEBP_QUALITY=90
IMAGE_PNG_COMPRESSION=6
RESPONSIVE_IMAGE_WIDTH_PROFILES={"default":[480,960,1440],"gallery":[640,1280,1920],"retail":[320,640,960]}

# -----------------------------------------------------------------------------
# Calendar Sync Foundation
# -----------------------------------------------------------------------------
CALENDAR_SYNC_ENABLED=true
CALENDAR_SYNC_DEFAULT_TIMEZONE=America/New_York
CALENDAR_SYNC_MAX_JOB_ATTEMPTS=5
