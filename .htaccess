Options All -Indexes
DirectoryIndex index.html index.php
RewriteEngine On

ErrorDocument 403 /error-documents/403.html
ErrorDocument 404 /error-documents/404.html
ErrorDocument 500 /error-documents/500.html
ErrorDocument 503 /error-documents/503.html

<IfModule mod_headers.c>
  Header always set Retry-After "3600" env=BOWWOW_MAINTENANCE
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy "base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "0"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Origin-Agent-Cluster "?1"
  Header always unset X-Powered-By
</IfModule>

# Canonical host + scheme. Keep this at the server layer so requests land on
# the non-www HTTPS origin in a single hop without PHP/frontend involvement.
RewriteCond %{HTTP_HOST} ^www\.bowwowsdogspa\.com$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://bowwowsdogspa.com%{REQUEST_URI} [R=301,L,NE]

# Block secret-bearing deploy archives before the real-file passthrough below.
RewriteRule ^(?:site-deploy|backend-deploy|frontend-deploy|server-config-deploy|deploy-[^/]+).*\.(?:zip|tar|tgz|tar\.gz)$ - [F,L,NC]

# serve existing static files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteCond %{DOCUMENT_ROOT}/maintenance.flag -f
RewriteCond %{REQUEST_URI} !^/admin(?:/|$) [NC]
RewriteCond %{REQUEST_URI} !^/api/health/?$ [NC]
RewriteCond %{REQUEST_URI} !^/api/admin(?:/|$) [NC]
RewriteCond %{REQUEST_URI} !^/error-documents(?:/|$) [NC]
RewriteRule ^ - [R=503,L,E=BOWWOW_MAINTENANCE:1]

RewriteRule ^admin(?:/.*)?$ admin/index.html [QSA,L]

RewriteRule ^api/?$ api/index.php [QSA,L]
RewriteRule ^api/(.*)$ api/$1 [QSA,L]

# Public SPA fallback.
RewriteRule ^ index.php [QSA,L]
