Options All -Indexes
DirectoryIndex index.html index.php
RewriteEngine On

ErrorDocument 403 /error-documents/403.html
ErrorDocument 404 /error-documents/404.html
ErrorDocument 500 /error-documents/500.html
ErrorDocument 503 /error-documents/503.html

<IfModule mod_headers.c>
Header always set Retry-After "3600" env=BOWWOW_MAINTENANCE
</IfModule>

# Legacy compatibility for the retired preview/current surfaces.
RewriteRule ^preview/?$ https://bowwowsdogspa.com/ [R=301,L,NE]
RewriteRule ^preview/(.*)$ https://bowwowsdogspa.com/$1 [R=301,L,NE]
RewriteRule ^current/?$ https://bowwowsdogspa.com/ [R=301,L,NE]
RewriteRule ^current/(.*)$ https://bowwowsdogspa.com/$1 [R=301,L,NE]

# Canonical host + scheme. Keep this at the server layer so requests land on
# the non-www HTTPS origin in a single hop without PHP/frontend involvement.
RewriteCond %{HTTP_HOST} ^www\.bowwowsdogspa\.com$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://bowwowsdogspa.com%{REQUEST_URI} [R=301,L,NE]

# Archived placeholder surface.
RewriteRule ^placeholder/?$ placeholder/index.php [QSA,L]

# serve existing static files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteCond %{DOCUMENT_ROOT}/maintenance.flag -f
RewriteCond %{REQUEST_URI} !^/admin(?:/|$) [NC]
RewriteCond %{REQUEST_URI} !^/api/health/?$ [NC]
RewriteCond %{REQUEST_URI} !^/api/admin(?:/|$) [NC]
RewriteCond %{REQUEST_URI} !^/error-documents(?:/|$) [NC]
RewriteCond %{REQUEST_URI} !^/placeholder(?:/|$) [NC]
RewriteRule ^ - [R=503,L,E=BOWWOW_MAINTENANCE:1]

RewriteRule ^admin(?:/.*)?$ admin/index.html [QSA,L]

RewriteCond %{DOCUMENT_ROOT}/backend/public -d
RewriteRule ^api/(.*)$ backend/public/$1 [QSA,L]
RewriteCond %{DOCUMENT_ROOT}/api/public -d
RewriteRule ^api/(.*)$ api/public/$1 [QSA,L]

# Public SPA fallback.
RewriteRule ^ index.php [QSA,L]
